# Target 平台
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_w6180=y
CONFIG_MTD_SPLIT_SUPPORT=y
CONFIG_MTD_SPLIT_FIRMWARE=y
CONFIG_MTD_CMDLINE_PARTS=y
CONFIG_MTD_SPLIT_UIMAGE_FW=y

# 32MB SPI NOR 闪存
CONFIG_PACKAGE_kmod-spi-nor=y
CONFIG_PACKAGE_kmod-mtd-rw=y
# 禁用NAND相关
# CONFIG_PACKAGE_kmod-nand-spl is not set
# CONFIG_PACKAGE_nand-utils is not set

# 镜像大小匹配firmware分区
CONFIG_IMAGE_SIZE="32448k"
CONFIG_TARGET_ROOTFS_INITRAMFS=y
CONFIG_BUILD_PATENTED=y

# MT7621 硬件加速
CONFIG_MIPS16=n
CONFIG_CPU_SUBTYPE_MIPS1004K=y
CONFIG_MT7621_GIC=y
CONFIG_MT7621_HWNAT=y
CONFIG_PACKAGE_kmod-mt7621-nat=y
CONFIG_PACKAGE_kmod-ipt-offload=y

# MT7905DAN WiFi6 闭源驱动
CONFIG_PACKAGE_mtk-wifi-da=y
CONFIG_PACKAGE_mt76da-firmware=y
CONFIG_PACKAGE_kmod-mt76-connac=y
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_iw-full=y
# 禁用开源mt76驱动避免冲突
# CONFIG_PACKAGE_kmod-mt76 is not set

# 网络BBR加速
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_DEFAULT_TCP_CONG_BBR=y
CONFIG_PACKAGE_flowoffload=y
CONFIG_PACKAGE_sqm-scripts=y

# LuCI中文基础
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-i18n-zh-cn=y
CONFIG_LUCI_LANG_zh-cn=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-app-network=y
CONFIG_PACKAGE_luci-app-system=y

# 基础工具
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_mtd-utils=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_screen=y
