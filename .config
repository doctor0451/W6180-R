# Target Platform
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_w6180=y
CONFIG_TARGET_ROOTFS_PARTSIZE=32512

# Flash Type: SPI NOR 32MB
CONFIG_PACKAGE_kmod-spi-nor=y
CONFIG_PACKAGE_kmod-mtd-rw=y
# Disable NAND related
# CONFIG_PACKAGE_kmod-nand-spl is not set
# CONFIG_PACKAGE_nand-utils is not set

# Memory & System
# CONFIG_TARGET_ROOTFS_PARTSIZE=32448
CONFIG_IMAGE_SIZE="32448k"
CONFIG_TARGET_ROOTFS_INITRAMFS=y
CONFIG_BUILD_PATENTED=y

# CPU Optimization MT7621
CONFIG_MIPS16=n
CONFIG_CPU_SUBTYPE_MIPS1004K=y
CONFIG_MT7621_GIC=y
CONFIG_MT7621_HWNAT=y
CONFIG_PACKAGE_kmod-mt7621-nat=y
CONFIG_PACKAGE_kmod-ipt-offload=y
