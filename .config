# ==================== 目标硬件平台 W6180 ====================
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_w6180=y
CONFIG_MTD_SPLIT_SUPPORT=y
CONFIG_MTD_SPLIT_FIRMWARE=y
CONFIG_MTD_SPLIT_UIMAGE_FW=y
CONFIG_MTD_CMDLINE_PARTS=y
CONFIG_MTD_BLOCK=y
# 32MB SPI NOR 闪存核心
CONFIG_MTD_SPI_NOR=y
CONFIG_PACKAGE_kmod-spi-nor=y
CONFIG_IMAGE_SIZE="32448k"
CONFIG_TARGET_ROOTFS_INITRAMFS=y
# 彻底禁用NAND闪存（避免冲突）
# CONFIG_MTD_NAND is not set
# CONFIG_PACKAGE_kmod-nand-spl is not set
# CONFIG_PACKAGE_nand-utils is not set

# ==================== MT7621 硬件基础 ====================
CONFIG_MIPS16=n
CONFIG_CPU_SUBTYPE_MIPS1004K=y
CONFIG_MT7621_GIC=y
# 硬件NAT先关闭，调试启动成功后再打开
# CONFIG_MT7621_HWNAT=y
# CONFIG_PACKAGE_kmod-mt7621-nat=y
# CONFIG_PACKAGE_flowoffload=y
CONFIG_PACKAGE_kmod-ipt-offload=y

# ==================== WiFi6 MT7905DAN 闭源驱动 屏蔽开源mt76 ====================
# 禁用开源mt76无线驱动（关键防崩溃）
# CONFIG_PACKAGE_kmod-mt76 is not set
# CONFIG_PACKAGE_kmod-mt76-core is not set
# 闭源MTK WiFi包
CONFIG_PACKAGE_mtk-wifi-da=y
CONFIG_PACKAGE_mt76da-firmware=y
CONFIG_PACKAGE_kmod-mt76-connac=y
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_iw-full=y
# CONFIG_PACKAGE_iw is not set

# ==================== 网络加速 TCP BBR / SQM ====================
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_DEFAULT_TCP_CONG_BBR=y
CONFIG_PACKAGE_sqm-scripts=y
CONFIG_PACKAGE_kmod-sched-cake=y
CONFIG_PACKAGE_kmod-sched-core=y
CONFIG_PACKAGE_kmod-ifb=y
CONFIG_PACKAGE_tc-tiny=y

# ==================== 防火墙、iptables nft ====================
CONFIG_PACKAGE_kmod-ipt-core=y
CONFIG_PACKAGE_kmod-ipt-ipopt=y
CONFIG_PACKAGE_kmod-nf-ipt=y
CONFIG_PACKAGE_nft-compat=y
CONFIG_PACKAGE_iptables-mod-ipopt=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_xtables-nft=y
CONFIG_PACKAGE_libiptext=y
CONFIG_PACKAGE_libiptext-nft=y
CONFIG_PACKAGE_libiptext6=y
CONFIG_PACKAGE_libxtables=y

# ==================== LuCI 中文界面基础 ====================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-i18n-zh-cn=y
CONFIG_LUCI_LANG_zh-cn=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-app-network=y
CONFIG_PACKAGE_luci-app-system=y

# ==================== 基础工具包 ====================
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_mtd-utils=y
CONFIG_PACKAGE_kmod-mtd-rw=y
CONFIG_PACKAGE_curl=y
CONFIG_LIBCURL_COOKIES=y
CONFIG_LIBCURL_CRYPTO_AUTH=y
CONFIG_LIBCURL_FILE=y
CONFIG_LIBCURL_FTP=y
CONFIG_LIBCURL_HTTP=y
CONFIG_LIBCURL_NGHTTP2=y
CONFIG_LIBCURL_OPENSSL=y
CONFIG_LIBCURL_PROXY=y
CONFIG_LIBCURL_TFTP=y
CONFIG_LIBCURL_THREADED_RESOLVER=y
CONFIG_LIBCURL_TLS_SRP=y
CONFIG_LIBCURL_UNIX_SOCKETS=y
CONFIG_PACKAGE_libcurl=y
CONFIG_PACKAGE_libnghttp2=y
CONFIG_PACKAGE_htop=y
CONFIG_HTOP_LMSENSORS=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_screen=y
CONFIG_PACKAGE_terminfo=y
CONFIG_PACKAGE_libbpf=y
CONFIG_PACKAGE_libelf=y
CONFIG_PACKAGE_libncurses=y
CONFIG_PACKAGE_zlib=y

# ==================== 编译全局开关 ====================
CONFIG_BUILD_PATENTED=y
